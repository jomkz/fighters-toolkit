{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ft-gui",
            "type": "shell",
            "command": "cmake --build build --target ft-gui --config Debug",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run ft-gui",
            "type": "shell",
            "command": "${workspaceFolder}/build/gui/Debug/ft-gui.exe",
            "dependsOn": "Build ft-gui",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
